# Production Environment Variables for Laudasist API
# Set these in Firebase App Hosting environment

# Firebase Admin SDK (service account JSON values)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=your-service-account-email

# Server
PORT=3001
NODE_ENV=production

# CORS - your Firebase Hosting URL
FRONTEND_URL=https://your-app.web.app
