{
  "name": "@laude/laudj",
  "version": "0.0.1",
  "private": true,
  "description": "LauDJ \u2014 live audio engine (Tauri + native Rust shell; audio STUBBED in the PoC) + web control panel (mixer, transport, section launcher, pads, session-follow).",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5175 --strictPort",
    "build": "tsc -b && vite build",
    "tauri": "tauri",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@laude/design-system": "file:../../packages/design-system",
    "@laude/i18n": "file:../../packages/i18n",
    "@laude/laudj-control-protocol": "file:../../packages/laudj-control-protocol",
    "@laude/pad-engine": "file:../../packages/pad-engine",
    "@laude/session": "file:../../packages/session",
    "@laude/song-model": "file:../../packages/song-model",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
