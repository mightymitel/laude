{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LauDJ",
  "version": "0.1.0",
  "identifier": "ro.laude.laudj",
  "build": {
    "devUrl": "http://localhost:5175",
    "frontendDist": "../dist",
