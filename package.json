{
  "name": "laude",
  "version": "0.1.0",
  "private": true,
  "description": "Worship Platform monorepo \u2014 Laudasist (apps/web + apps/api, Firebase), the session relay (apps/relay), LauDJ (apps/laudj) and LaudStudio (apps/studio) over shared @laude/* packages.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "poc": "bash scripts/poc.sh",
    "seed": "npm run seed -w apps/studio",
    "emulators": "firebase emulators:start --project demo-laude --import .emulator-data --export-on-exit .emulator-data",
    "dev:web": "npm run dev -w apps/web",
    "dev:api": "npm run dev -w apps/api",
    "dev:laudj": "npm run dev -w apps/laudj",
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint . --ext .ts,.tsx",
    "check:boundaries": "node scripts/check-boundaries.mjs",
    "test": "npm run check:boundaries && npm run test --workspaces --if-present",
    "test:e2e": "npx tsx scripts/e2e-runner.ts",
    "apphosting:build": "npm run build -w @laudasist/shared && npm run build -w web && npm run build -w @laudasist/api",
    "test:rules": "npx tsx scripts/rules-test.ts"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.57.0",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "concurrently": "^9.0.0",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.2"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true,
    "@firebase/util@1.15.1": true
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
